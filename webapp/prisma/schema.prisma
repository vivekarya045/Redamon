  updateGraphDb               Boolean  @default(true) @map("update_graph_db")
  useTorForRecon              Boolean  @default(false) @map("use_tor_for_recon")
  useBruteforceForSubdomains  Boolean  @default(false) @map("use_bruteforce_for_subdomains")

  // ========== WHOIS/DNS ==========
