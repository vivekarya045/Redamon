  // ========== JSLUICE JS ANALYZER ==========
  jsluiceEnabled              Boolean  @default(true) @map("jsluice_enabled")
  jsluiceMaxFiles             Int      @default(10000) @map("jsluice_max_files")
  jsluiceTimeout              Int      @default(300) @map("jsluice_timeout")
  jsluiceExtractUrls          Boolean  @default(true) @map("jsluice_extract_urls")
  jsluiceExtractSecrets       Boolean  @default(true) @map("jsluice_extract_secrets")
  jsluiceConcurrency          Int      @default(5) @map("jsluice_concurrency")
  jsluiceParallelism          Int      @default(5) @map("jsluice_parallelism")

  // ========== JS RECON SCANNER ==========
